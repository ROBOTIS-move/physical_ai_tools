FROM robotis/ros:jazzy-ros-base-torch2.7.0-cuda12.8.0 AS physical-ai-tools

ARG S6_OVERLAY_VERSION=3.2.1.0

# Install s6-overlay
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz /tmp
RUN tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-x86_64.tar.xz /tmp
RUN tar -C / -Jxpf /tmp/s6-overlay-x86_64.tar.xz

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive

# Update GPG keys and package lists
# Some GPG errors may occur but we try to continue
RUN apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    apt-get update --allow-releaseinfo-change 2>&1 || \
    (apt-get install -y --no-install-recommends ca-certificates gnupg && \
     apt-get update --allow-releaseinfo-change) || \
    apt-get update || true

# Install realsense and physical_ai_tools dependencies
RUN apt-get install -y \
    xz-utils \
    ffmpeg \
    vim \
    nano \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONPATH=$PYTHONPATH:/usr/local/lib

ENV COLCON_WS=/root/ros2_ws
WORKDIR ${COLCON_WS}

RUN mkdir -p ${COLCON_WS}/src && \
    cd ${COLCON_WS}/src && \
    git clone -b jazzy https://github.com/ROBOTIS-GIT/physical_ai_tools.git --recursive

RUN cd ${COLCON_WS} && \
    apt-get update && \
    rosdep update && \
    rosdep install -i --from-path src --rosdistro $ROS_DISTRO -y && \
    rm -rf /var/lib/apt/lists/*

RUN cd ${COLCON_WS}/src/physical_ai_tools/lerobot && \
    sed -i '/"torch[^\"]*",/d' pyproject.toml && \
    sed -i '/"torchvision[^\"]*",/d' pyproject.toml && \
    pip install --ignore-installed -e .

RUN cd ${COLCON_WS}/src/physical_ai_tools/lerobot && \
    pip install -e ".[smolvla]"

RUN pip install setuptools==68.1.2
RUN pip install 'numpy<2'

RUN echo 'export PYTHONPATH=${COLCON_WS}/src/physical_ai_tools/lerobot/src:$PYTHONPATH' >> /root/.bashrc && \
    export PYTHONPATH=${COLCON_WS}/src/physical_ai_tools/lerobot/src:$PYTHONPATH

RUN bash -c "source /opt/ros/${ROS_DISTRO}/setup.bash && \
    cd ${COLCON_WS} && \
    colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Release"

RUN echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> ~/.bashrc  && \
    echo "source ${COLCON_WS}/install/setup.bash" >> ~/.bashrc  && \
    echo "alias cb='colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Release'" >> ~/.bashrc && \
    echo "alias ai_server='ros2 launch physical_ai_server physical_ai_server_bringup.launch.py'" >> ~/.bashrc && \
    echo "export ROS_DOMAIN_ID=30" >> ~/.bashrc

# Create directory for agent Unix Domain Socket
# The agent will create /var/run/agent/s6_agent.sock
RUN mkdir -p /var/run/agent && \
    chmod 777 /var/run/agent

# Note: system_manager will be mounted via docker-compose volume
# Create directory for it
RUN mkdir -p /opt/system_manager
ENV PYTHONPATH=/opt/system_manager:${PYTHONPATH}

RUN pip config set global.break-system-packages true

# Install system_manager requirements (will be available via volume mount)
# Create a temporary requirements file for installation
RUN echo "fastapi==0.128.0" > /tmp/system_manager_requirements.txt && \
    echo "uvicorn[standard]==0.40.0" >> /tmp/system_manager_requirements.txt && \
    echo "pydantic==2.12.5" >> /tmp/system_manager_requirements.txt && \
    echo "pyyaml==6.0.1" >> /tmp/system_manager_requirements.txt && \
    echo "docker==7.1.0" >> /tmp/system_manager_requirements.txt && \
    echo "requests==2.32.5" >> /tmp/system_manager_requirements.txt && \
    echo "requests-unixsocket==0.4.1" >> /tmp/system_manager_requirements.txt && \
    pip install --no-cache-dir -r /tmp/system_manager_requirements.txt && \
    rm /tmp/system_manager_requirements.txt

# ROS2 physical_ai_server service (longrun) with logging pipeline
# Main service
COPY docker/s6-services/physical_ai_server /etc/s6-overlay/s6-rc.d/physical_ai_server
RUN chmod +x /etc/s6-overlay/s6-rc.d/physical_ai_server/run && \
    chmod +x /etc/s6-overlay/s6-rc.d/physical_ai_server/finish

# Log preparation oneshot service
COPY docker/s6-services/physical_ai_server-log-prepare /etc/s6-overlay/s6-rc.d/physical_ai_server-log-prepare

# Logging service (consumer)
COPY docker/s6-services/physical_ai_server-log /etc/s6-overlay/s6-rc.d/physical_ai_server-log
RUN chmod +x /etc/s6-overlay/s6-rc.d/physical_ai_server-log/run

# Copy reusable ROS2 service scripts to a location outside s6-rc.d
# This prevents s6-rc-compile from treating them as services
RUN mkdir -p /usr/local/lib/s6-services
COPY docker/s6-services/common/ros2_service_run.sh /usr/local/lib/s6-services/ros2_service_run.sh
COPY docker/s6-services/common/ros2_service_finish.sh /usr/local/lib/s6-services/ros2_service_finish.sh
RUN chmod +x /usr/local/lib/s6-services/ros2_service_run.sh && \
    chmod +x /usr/local/lib/s6-services/ros2_service_finish.sh

# Create log directory and set permissions
RUN mkdir -p /var/log/physical_ai_server && \
    chown nobody:nogroup /var/log/physical_ai_server && \
    chmod 02755 /var/log/physical_ai_server

# Note: s6-agent service will be mounted via docker-compose volume
# Add s6-agent to user bundle so it starts at container boot
# Note: physical_ai_server-pipeline is NOT in the user bundle - it must be started manually
RUN mkdir -p /etc/s6-overlay/s6-rc.d/user/contents.d && \
    touch /etc/s6-overlay/s6-rc.d/user/contents.d/s6-agent

# Set s6-overlay as entrypoint
ENTRYPOINT ["/init"]
